clc; clear; close all;

Fs = 200;              
N = 20;                
n = 0:N-1;

A = 1;
B = A + 5;

f1 = 50 + A;
f2 = 50 + B;


x = cos(2*pi*f1/Fs .* n) + cos(2*pi*f2/Fs .* n);

X = fft(x);
f = (0:N-1)*(Fs/N);


figure;
plot(f, abs(X), 'LineWidth', 1.5,Color='r');
xlabel('Frequency (Hz)');
ylabel('|X(k)|');
title('FFT Spectrum (N = 20)');
grid on;
